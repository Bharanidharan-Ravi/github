{
  "name": "microfrontends-root",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:shell": "pnpm --filter shell dev",
    "dev:auth": "pnpm --filter auth dev",
    "dev:tickets": "pnpm --filter tickets dev",
    "dev:client": "pnpm --filter client dev",
    "dev:all": "concurrently -k \"pnpm --filter tickets dev\" \"pnpm --filter auth dev\" \"wait-on http://localhost:5003/assets/remoteEntry.js && wait-on http://localhost:5002/assets/remoteEntry.js && pnpm --filter shell dev\"",
    "shell": "pnpm --filter shell dev",
    "auth": "pnpm --filter auth dev",
    "tickets": "pnpm --filter tickets dev",
    "client": "pnpm --filter client dev",
    "all": "pnpm --filter shell dev && pnpm --filter auth dev && pnpm --filter tickets dev && pnpm --filter employee dev",
    "build:shell": "pnpm --filter shared-store build && pnpm --filter shared-signalr build && pnpm --filter shell build",
    "build:auth": "pnpm --filter auth build",
    "build:client": "pnpm --filter client build",
    "build:tickets": "pnpm --filter shared-store build && pnpm --filter tickets build",
    "build:all": "pnpm --filter shared-store build && pnpm --filter shared-signalr build && pnpm --filter auth build && pnpm build:tickets && pnpm -F shell build",
    "preview:all": "concurrently -n shell,auth,tickets,client -c blue,green,yellow,red \"pnpm --filter shell preview\" \"pnpm --filter auth preview\" \"pnpm --filter tickets preview\" \"pnpm --filter client preview\"",
    "clean": "node ./scripts/clean.js",
    "reinstall": "pnpm install"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@microsoft/signalr": "^9.0.6",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@reduxjs/toolkit": "^2.9.2",
    "@tiptap/core": "^2.10.4",
    "@tiptap/extension-image": "^2.10.4",
    "@tiptap/extension-link": "^2.10.4",
    "@tiptap/extension-mention": "^2.10.4",
    "@tiptap/extension-placeholder": "^2.10.4",
    "@tiptap/extension-table": "^2.10.4",
    "@tiptap/extension-table-cell": "^2.10.4",
    "@tiptap/extension-table-header": "^2.10.4",
    "@tiptap/extension-table-row": "^2.10.4",
    "@tiptap/extension-underline": "^2.10.4",
    "@tiptap/react": "^2.10.4",
    "@tiptap/starter-kit": "^2.10.4",
    "axios": "^1.13.2",
    "bootstrap": "^5.3.8",
    "bowser": "^2.12.1",
    "crypto-js": "^4.2.0",
    "dompurify": "^3.3.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.554.0",
    "prosemirror-model": "^1.19.4",
    "prosemirror-state": "^1.4.3",
    "prosemirror-transform": "^1.8.0",
    "prosemirror-view": "^1.34.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.5",
    "react-toastify": "^11.0.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-plugin-react-compiler": "^19.1.0-rc.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.2",
    "terser": "^5.44.1",
    "vite": "^7.1.7",
    "wait-on": "^9.0.3"
  }
}